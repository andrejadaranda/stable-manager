# Copy this file to .env.local and fill in real values from your Supabase project.
# Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — used by Stripe webhook / admin scripts.
# NEVER expose this in client-side code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL — used as a fallback for emailRedirectTo when no Host
# header is available (e.g. background jobs). The signup action prefers
# the live request host, so dev/preview/prod all "just work" without
# changing this. Keep it pointing at the canonical prod URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — used for transactional email (waitlist welcome, etc.).
# The same API key is also pasted into Supabase Dashboard → Auth → SMTP
# so confirmation emails route through Resend. See docs/AUTH-SETUP.md.
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@longrein.eu
RESEND_FROM_NAME=Longrein

# ---------------- Stripe ----------------
# REQUIRED before public launch (M6, November 2026). Founding-member
# launch (May 23 2026) ships without these — FMs are on 12-month free
# SaaS and never enter a Stripe checkout flow.
#
# Wiring (see app/api/stripe/webhook/route.ts header comment):
#   1. Create products + prices in Stripe Dashboard (one per tier).
#   2. Add webhook endpoint → /api/stripe/webhook ; copy signing secret.
#   3. Apply migration 36_billing_schema_consolidation.sql to the DB.
#   4. Verify webhook with `stripe trigger checkout.session.completed`.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=
