# Copy to .env.local and fill in. Do NOT commit .env.local.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — used by /api/waitlist welcome email + (later) Supabase Auth SMTP.
# Create at https://resend.com/api-keys with "Sending access" scope.
# Domain longrein.eu must be verified at https://resend.com/domains first.
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@longrein.eu
RESEND_FROM_NAME=Longrein
